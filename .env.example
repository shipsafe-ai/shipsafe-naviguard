# Vertex AI path (required — all LLM calls use Gemini via Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1

# Model override (optional)
GEMINI_MODEL=gemini-2.5-flash

# Phoenix Cloud — copy from app.phoenix.arize.com → Settings
# Format: px_live_...
PHOENIX_API_KEY=

# Hostname from Phoenix Settings (includes /s/<space>)
# Example: https://app.phoenix.arize.com/s/prateek-srivastava23
PHOENIX_COLLECTOR_ENDPOINT=

# Phoenix project name
PHOENIX_PROJECT_NAME=naviguard

# Phoenix base URL (for MCP and client SDK)
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/prateek-srivastava23

# API server
PORT=8080
